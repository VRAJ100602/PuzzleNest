# ─────────────────────────────────────────────────────────────────────────────
# PuzzleNest — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit your real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core security (REQUIRED in production) ───────────────────────────────────
# Signing key for JWTs. The app REFUSES TO BOOT in production if this is unset,
# the placeholder, or shorter than 32 chars. Generate a strong one:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# "development" or "production". Production enables HSTS, disables /docs, and
# enforces the SECRET_KEY check above.
ENV=development

# ── Network / host hardening ─────────────────────────────────────────────────
# Comma-separated Host allowlist (blocks Host-header injection). Leave empty in
# dev. In production set to your domain(s):
#   ALLOWED_HOSTS=puzzlenest.app,www.puzzlenest.app
ALLOWED_HOSTS=

# Comma-separated CORS origins allowed to call the API from a browser.
ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081,http://localhost:3000

# Max accepted request body in bytes (default 1 MiB). Requests larger are 413'd.
MAX_BODY_BYTES=1048576

# Public base URL, used to build password-reset links in emails.
SITE_URL=http://localhost:8000

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite for dev. Use PostgreSQL in production:
#   DATABASE_URL=postgresql+psycopg://user:pass@host:5432/puzzlenest
DATABASE_URL=sqlite:///./puzzle_hub.db

# ── Outbound email (password reset). Optional — if blank, reset links are
#    logged to the server console instead of emailed. ─────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=PuzzleNest <no-reply@puzzlenest.app>

# ── Razorpay (Premium billing). Leave blank to disable billing in dev. ───────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID_MONTHLY=
PREMIUM_MONTHLY_PRICE_PAISE=9900
